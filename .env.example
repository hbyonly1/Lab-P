# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=lab_p
POSTGRES_PORT=5432

# Redis Server
REDIS_PORT=6379

# Public web entry for Sakura FRP / reverse proxy.
# Sakura FRP should forward to 127.0.0.1:${PUBLIC_WEB_PORT}.
PUBLIC_WEB_PORT=8080
BACKEND_PORT=8000

# Production build should usually keep this empty so the frontend calls same-origin /api/v1.
# Only set it when frontend and backend are intentionally deployed on different origins.
VITE_API_BASE_URL=

# AI Settings
# 全站 AI 服务统一使用 OpenAI-compatible Chat Completions 接口。
# 不要提交真实 key 到公开仓库；生产环境建议通过部署环境变量注入。

# [每次 AI 调用都会读取] 真实 API Key 只放这里，不写入数据库，也不会返回前端。
# 修改后需要重启后端进程。
AI_API_KEY=

# [仅首次初始化读取] 下面这些值只在 ai_config 表为空时用于创建第一条数据库配置。
# 一旦 Admin 设置页已经生成/保存过 AI 配置，运行时以后端数据库 ai_config 为准。
# 后续要改 Base URL、模型、温度、超时、自动识别、验证码 prompt，请在 Admin 设置页修改。
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://api.siliconflow.cn/v1
AI_DEFAULT_MODEL=deepseek-ai/DeepSeek-V4-Flash
AI_IMAGE_RECOGNITION_MODEL=zai-org/GLM-4.5V
AI_ANSWER_GENERATION_MODEL=deepseek-ai/DeepSeek-V4-Flash
AI_CAPTCHA_MODEL=zai-org/GLM-4.5V

# Backend Settings
# 自定义初始管理员的账号密码
# 若取消 ADMIN_PASSWORD 的注释并配置了密码，则后台启动时将不再随机生成。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Comma-separated origins for development or split-origin deployments.
# Same-origin Sakura FRP deployment does not need the public domain here.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
